#!/usr/bin/env bash
# AUR-GUARD-SHIM-MARKER  (do not remove — package scriptlets use this to
# verify the shim is ours before touching /usr/local/bin/makepkg)
# makepkg shim that passes through aur-guard before calling the real makepkg.
#
# Install: place at /usr/local/bin/makepkg (mode 0755). /usr/local/bin precedes
# /usr/bin in the default PATH, so paru, yay and any user invoking `makepkg`
# directly will go through this script.
#
# Variables:
#   AUR_GUARD_BIN          aur-guard binary (default /usr/local/bin/aur-guard)
#   AUR_GUARD_REAL_MAKEPKG path to the real makepkg (default /usr/bin/makepkg)
#   AUR_GUARD_DISABLE=1    skip the scan (not recommended)

set -u

AUR_GUARD_BIN="${AUR_GUARD_BIN:-/usr/local/bin/aur-guard}"
AUR_GUARD_REAL_MAKEPKG="${AUR_GUARD_REAL_MAKEPKG:-/usr/bin/makepkg}"

if [[ "${AUR_GUARD_DISABLE:-0}" == "1" ]]; then
    exec "$AUR_GUARD_REAL_MAKEPKG" "$@"
fi

if [[ ! -x "$AUR_GUARD_BIN" ]]; then
    printf 'aur-guard :: binary not found at %s; skipping scan.\n' "$AUR_GUARD_BIN" >&2
    exec "$AUR_GUARD_REAL_MAKEPKG" "$@"
fi

if [[ ! -x "$AUR_GUARD_REAL_MAKEPKG" ]]; then
    printf 'aur-guard :: real makepkg not found at %s.\n' "$AUR_GUARD_REAL_MAKEPKG" >&2
    exit 127
fi

exec "$AUR_GUARD_BIN" makepkg-wrap --real "$AUR_GUARD_REAL_MAKEPKG" -- "$@"
