#!/usr/bin/env bash
# Shim de makepkg que pasa por aur-guard antes de llamar al makepkg real.
#
# Instalación: colocar en /usr/local/bin/makepkg (con permisos 0755). /usr/local/bin
# precede a /usr/bin en el PATH por defecto, por lo que paru, yay y los usuarios
# que invoquen `makepkg` directamente pasarán por aquí.
#
# Variables:
#   AUR_GUARD_BIN          binario aur-guard (por defecto /usr/local/bin/aur-guard)
#   AUR_GUARD_REAL_MAKEPKG ruta al makepkg real (por defecto /usr/bin/makepkg)
#   AUR_GUARD_DISABLE=1    saltarse el escaneo (no recomendado)

set -u

AUR_GUARD_BIN="${AUR_GUARD_BIN:-/usr/local/bin/aur-guard}"
AUR_GUARD_REAL_MAKEPKG="${AUR_GUARD_REAL_MAKEPKG:-/usr/bin/makepkg}"

if [[ "${AUR_GUARD_DISABLE:-0}" == "1" ]]; then
    exec "$AUR_GUARD_REAL_MAKEPKG" "$@"
fi

if [[ ! -x "$AUR_GUARD_BIN" ]]; then
    printf 'aur-guard :: binario no encontrado en %s; saltando análisis.\n' "$AUR_GUARD_BIN" >&2
    exec "$AUR_GUARD_REAL_MAKEPKG" "$@"
fi

if [[ ! -x "$AUR_GUARD_REAL_MAKEPKG" ]]; then
    printf 'aur-guard :: makepkg real no encontrado en %s.\n' "$AUR_GUARD_REAL_MAKEPKG" >&2
    exit 127
fi

exec "$AUR_GUARD_BIN" makepkg-wrap --real "$AUR_GUARD_REAL_MAKEPKG" -- "$@"
