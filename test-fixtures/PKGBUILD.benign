# Maintainer: Example <example@domain.tld>
pkgname=hello-world
pkgver=1.0.0
pkgrel=1
pkgdesc="Benign example program"
arch=('x86_64')
url="https://example.org/hello-world"
license=('MIT')
depends=('glibc')
makedepends=('gcc')
source=("https://example.org/releases/${pkgname}-${pkgver}.tar.gz")
sha256sums=('a1b2c3d4e5f6071829384756abcdef0123456789abcdef0123456789abcdef01')

build() {
    cd "${pkgname}-${pkgver}"
    make
}

package() {
    cd "${pkgname}-${pkgver}"
    make DESTDIR="$pkgdir" install
}
