# Maintainer: Ejemplo <ejemplo@dominio.tld>
pkgname=hola-mundo
pkgver=1.0.0
pkgrel=1
pkgdesc="Programa de ejemplo benigno"
arch=('x86_64')
url="https://example.org/hola-mundo"
license=('MIT')
depends=('glibc')
makedepends=('gcc')
source=("https://example.org/releases/${pkgname}-${pkgver}.tar.gz")
sha256sums=('a1b2c3d4e5f6071829384756abcdef0123456789abcdef0123456789abcdef01')

build() {
    cd "${pkgname}-${pkgver}"
    make
}

package() {
    cd "${pkgname}-${pkgver}"
    make DESTDIR="$pkgdir" install
}
